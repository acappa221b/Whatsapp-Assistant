{
  "name": "finance-ai",
  "version": "0.0.9",
  "private": true,
  "description": "Dashboard Financeiro Inteligente integrado ao WhatsApp",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "harness": "tsx harness/run-all.ts",
    "validate:repo-hygiene": "node scripts/validate-no-runtime-data.mjs",
    "rc:05:diagnostic": "tsx scripts/rc-05-diagnostic.ts",
    "rc:06:backfill-names": "tsx packages/database/scripts/rc-06-backfill-names.ts",
    "rc:07:names-diagnostic": "tsx scripts/rc-07-names-diagnostic.ts",
    "rc:09:reset-all-history": "tsx packages/database/scripts/rc-09-reset-all-history.ts",
    "rc:09:names-diagnostic": "tsx scripts/rc-09-names-diagnostic.ts",
    "db:generate": "pnpm --filter @finance-ai/database db:generate",
    "db:migrate": "pnpm --filter @finance-ai/database db:migrate",
    "db:studio": "pnpm --filter @finance-ai/database db:studio",
    "postinstall": "node scripts/postinstall.mjs",
    "launch": "node scripts/launch.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
