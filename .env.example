NODE_ENV=development
PORT=4000
TZ=America/Sao_Paulo
APP_NAME="WhatsApp Assistant"
APP_VERSION=1.0.5-rc07

DATABASE_URL="file:./packages/database/prisma/dev.db"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
OPENAI_TIMEOUT_MS=60000
OPENAI_RETRY_ATTEMPTS=3
OPENAI_RETRY_DELAY_MS=1000
OPENAI_INPUT_PRICE_PER_1M_BRL=0.00
OPENAI_OUTPUT_PRICE_PER_1M_BRL=0.00
OPENAI_AVG_COST_PER_1K_TOKENS_BRL=0.002

WHATSAPP_SESSION_PATH="./storage/whatsapp"
# ID do grupo (@g.us) — use logs [WhatsApp/Group-Discovery] para descobrir; NÃO use @lid do remetente
WHATSAPP_MONITORED_CHAT_ID=
WHATSAPP_IGNORE_HISTORY=true
WHATSAPP_AUTO_RECONNECT=true
WHATSAPP_RECONNECT_DELAY_MS=5000

MEDIA_STORAGE_PATH="./storage/media"
TEMP_STORAGE_PATH="./storage/temp"

COMPANY_NAME="Minha Empresa"
DEFAULT_CURRENCY=BRL

LOG_LEVEL=info
LOG_PRETTY_PRINT=true

AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=3650

BACKUP_ENABLED=true
BACKUP_PATH="./backups"

CI=false
DOCKER_BUILD=false
